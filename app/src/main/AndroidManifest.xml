<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity
            android:name="hitsz.application.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="hitsz.application.DifficultySelectionActivity"
            android:exported="false"
            android:label="难度设置"
            android:theme="@style/Theme.MyApplication">
        </activity>
        <activity
            android:name="hitsz.application.RankListActivity"
            android:exported="false"
            android:label="排行榜"
            android:theme="@style/Theme.MyApplication">
        </activity>
        <activity
            android:name="hitsz.application.SettingsActivity"
            android:exported="false"
            android:label="音乐设置"
            android:theme="@style/Theme.MyApplication">
        </activity>
        <activity
            android:name="hitsz.application.LoginActivity"
            android:exported="false"
            android:label="用户登录"
            android:theme="@style/Theme.MyApplication">
        </activity>
        <activity
            android:name="hitsz.application.RegisterActivity"
            android:exported="false"
            android:label="用户注册"
            android:theme="@style/Theme.MyApplication">
        </activity>
        <activity
            android:name="hitsz.application.OnlineActivity"
            android:exported="false"
            android:label="在线对战"
            android:theme="@style/Theme.MyApplication">
        </activity>
        <activity
            android:name="hitsz.application.OverActivity"
            android:exported="false"
            android:label="对战结果"
            android:theme="@style/Theme.MyApplication">
        </activity>
    </application>

</manifest>